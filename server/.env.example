# ---------------------------------------------------------------------------
# Project / API
# ---------------------------------------------------------------------------
PROJECT_NAME=OmniSource
LOG_LEVEL=INFO
SLOW_REQUEST_THRESHOLD_MS=2000.0

# ---------------------------------------------------------------------------
# Data stores
# ---------------------------------------------------------------------------
MONGODB_URL=mongodb://mongo:27017/omnisource_db
REDIS_URL=redis://redis:6379/0
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_OPERATION_TIMEOUT_SECONDS=2.5

# ---------------------------------------------------------------------------
# Security / auth
# IMPORTANT: change SECRET_KEY in real deployments
# ---------------------------------------------------------------------------
SECRET_KEY=change_me_to_a_strong_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=12
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900

# ---------------------------------------------------------------------------
# Image proxy cache
# ---------------------------------------------------------------------------
IMAGE_PROXY_CACHE_TTL_SECONDS=3600
IMAGE_PROXY_CACHE_MAX_ITEMS=500
IMAGE_PROXY_MAX_BYTES_PER_ITEM=5242880
IMAGE_PROXY_CACHE_MAX_TOTAL_BYTES=67108864
IMAGE_PROXY_MAX_REDIRECTS=4

# ---------------------------------------------------------------------------
# SMTP
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change_me
EMAILS_FROM_EMAIL=noreply@example.com

# ---------------------------------------------------------------------------
# External content providers
# ---------------------------------------------------------------------------
TMDB_API_KEY=replace_me
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
GOOGLE_BOOKS_API_KEY=replace_me
