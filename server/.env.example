# ---------------------------------------------------------------------------
# Project / API
# ---------------------------------------------------------------------------
PROJECT_NAME=OmniSource
LOG_LEVEL=INFO
SLOW_REQUEST_THRESHOLD_MS=2000.0

# ---------------------------------------------------------------------------
# ML / recommendations
# ---------------------------------------------------------------------------
ML_VECTOR_INDEX_ENABLED=false
ML_VECTOR_INDEX_TTL_SECONDS=600
ML_VECTOR_INDEX_MAX_ITEMS=0
ML_VECTOR_BACKEND=hash
ML_VECTOR_SEARCH_MULTIPLIER=120
ML_EVAL_HOLDOUT_MIN_POSITIVES=2
ML_EVENT_WEIGHT_VIEW=0.2
ML_EVENT_WEIGHT_OPEN_DETAIL=0.5
ML_EVENT_WEIGHT_DWELL_TIME=0.3
ML_EVENT_WEIGHT_SEARCH=0.1
ML_EVENT_WEIGHT_LIKE=1.0
ML_EVENT_WEIGHT_PLAYLIST_ADD=0.8
ML_HYBRID_SIMILARITY_WEIGHT=0.78
ML_HYBRID_RATING_WEIGHT=0.14
ML_HYBRID_GENRE_WEIGHT=0.08
ML_INTEREST_SIMILARITY_WEIGHT=0.8
ML_INTEREST_RATING_WEIGHT=0.12
ML_INTEREST_TAG_WEIGHT=0.08
CACHE_WARMUP_TAG_LIMIT=30
CACHE_WARMUP_USER_LIMIT=500

# ---------------------------------------------------------------------------
# Data stores
# ---------------------------------------------------------------------------
MONGODB_URL=mongodb://mongo:27017/omnisource_db
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_OPERATION_TIMEOUT_SECONDS=2.5

# ---------------------------------------------------------------------------
# Security / auth
# Provide real RSA key files for persistent JWT signing.
# ---------------------------------------------------------------------------
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_PRIVATE_KEY_PATH=certs/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=certs/public.pem
AUTH_JWT_ALLOW_EPHEMERAL_KEYS=true
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=12
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_PASSWORD_RESET_RATE_LIMIT_ATTEMPTS=5
AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900

# ---------------------------------------------------------------------------
# Image proxy cache
# ---------------------------------------------------------------------------
IMAGE_PROXY_CACHE_TTL_SECONDS=3600
IMAGE_PROXY_CACHE_MAX_ITEMS=500
IMAGE_PROXY_MAX_BYTES_PER_ITEM=5242880
IMAGE_PROXY_CACHE_MAX_TOTAL_BYTES=67108864
IMAGE_PROXY_MAX_REDIRECTS=4

# ---------------------------------------------------------------------------
# SMTP
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change_me
EMAILS_FROM_EMAIL=noreply@example.com

# ---------------------------------------------------------------------------
# External content providers
# ---------------------------------------------------------------------------
TMDB_API_KEY=replace_me
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
GOOGLE_BOOKS_API_KEY=replace_me
